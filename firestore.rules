rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function isInternalUser() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAuthenticated() &&
        userData.role in ['owner', 'admin', 'sales_rep', 'contractor', 'pm'] &&
        userData.status == 'active';
    }

    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isOwnDocument(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPartner() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';
    }

    function isContractor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor';
    }

    function getUserPartnerId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId;
    }

    // Config collection (feature flags, app settings)
    // All authenticated users can read; only owner can write
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }

    // Users collection
    match /users/{userId} {
      // Anyone can create their own user document (signup)
      // Enforce: must be pending status, no self-assigned privileged role,
      // and cannot set admin-only fields
      allow create: if isAuthenticated() && request.auth.uid == userId &&
        (
          // Standard signup: pending status, no privileged fields
          (request.resource.data.status == 'pending' &&
           request.resource.data.role == 'pending' &&
           !request.resource.data.keys().hasAny(['approvedAt', 'approvedBy']))
          ||
          // Customer self-signup: auto-activated
          (request.resource.data.status == 'active' &&
           request.resource.data.role == 'customer' &&
           request.resource.data.requestedRole == 'customer')
          ||
          // First-user-is-owner: auto-promoted when no admins exist
          // The client checks if users collection has any owner/admin before setting this
          (request.resource.data.status == 'active' &&
           request.resource.data.role == 'owner' &&
           request.resource.data.get('approvedBy', '') == 'auto-first-user')
        );

      // Active users can read user profiles (needed for messaging contacts, user lookups)
      allow read: if isOwnDocument(userId) || isActiveUser();

      // Only admins can update user status/role, users can update own profile fields
      allow update: if isAdmin() ||
        (isOwnDocument(userId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'approvedAt', 'approvedBy']));

      // Only owner can delete users
      allow delete: if isOwner();

      // Integrations subcollection (Google Calendar, etc.)
      match /integrations/{integrationId} {
        // Users can only read/write their own integrations
        allow read, write: if isOwnDocument(userId);
      }
    }

    // Contractors collection
    match /contractors/{contractorId} {
      // Internal users can read all contractors (needed for job assignment, availability views)
      // Per PRD: Owner, Admin, PM can see all contractors
      // Contractors can read their own record (for profile page, lead feed)
      allow read: if isInternalUser() ||
        (isActiveUser() && resource.data.userId == request.auth.uid) ||
        (isActiveUser() && resource.data.email == request.auth.token.email);

      // Admins can create/update, contractors can update their own (limited fields)
      // Contractors can also create their own record (auto-creation from profile page)
      allow create: if isAdmin() ||
        (isContractor() && isActiveUser() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() ||
        (isActiveUser() && resource.data.userId == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'status', 'userId', 'tier', 'commissionRate', 'approvedAt', 'approvedBy']));

      allow delete: if isOwner();

      // Sensitive payment data subcollection (ACH info, etc.)
      // Only admins can read/write payment data
      match /paymentInfo/{docId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }

      // Appointments subcollection (booked via AI voice or in-app)
      match /appointments/{appointmentId} {
        // Internal users can read all appointments (admin calendar needs collection group query)
        allow read: if isInternalUser();

        // Admins can create/update/delete
        allow create, update: if isAdmin();

        // The contractor themselves can read/update their own appointments
        allow update: if isActiveUser() &&
          get(/databases/$(database)/documents/contractors/$(contractorId)).data.userId == request.auth.uid;

        allow delete: if isAdmin();
      }

      // Availability subcollection
      match /availability/{dateId} {
        // Internal users can read availability (needed for scheduling)
        allow read: if isInternalUser();

        // Admins and the contractor themselves can manage availability
        allow create, update: if isAdmin() ||
          (isActiveUser() && get(/databases/$(database)/documents/contractors/$(contractorId)).data.userId == request.auth.uid);

        allow delete: if isAdmin() ||
          (isActiveUser() && get(/databases/$(database)/documents/contractors/$(contractorId)).data.userId == request.auth.uid);
      }
    }

    // Jobs collection
    match /jobs/{jobId} {
      // Internal users can read jobs (UI filters based on role)
      // This allows list queries to work; frontend controls what's displayed
      allow read: if isInternalUser();

      // Admins can create any job
      // Sales reps can create jobs where they are the sales rep
      allow create: if isAdmin() ||
        (isActiveUser() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales_rep' &&
          request.resource.data.salesRepId == request.auth.uid);

      // Status updates based on role
      allow update: if isAdmin() ||
        (isActiveUser() && (
          // PM can update most fields but cannot change salesRepId, pmId, or financial fields
          (resource.data.pmId == request.auth.uid &&
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['salesRepId', 'pmId', 'contractAmount', 'commissionRate'])) ||
          // Sales rep can update their own jobs (status, crew, photos, etc.)
          // but cannot change salesRepId or pmId
          (resource.data.salesRepId == request.auth.uid &&
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['salesRepId', 'pmId'])) ||
          // Crew members (contractors) can update photos field only
          (request.auth.uid in resource.data.crewIds &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photos', 'updatedAt']))
        ));

      allow delete: if isOwner();

      // Job addendums subcollection
      match /addendums/{addendumId} {
        // Internal users can read all addendums
        allow read: if isInternalUser();

        // Internal users can create addendums (contractor in field, PM, admin)
        allow create: if isInternalUser() && isActiveUser();

        // Only admins can update (void) addendums
        allow update: if isAdmin();

        allow delete: if isOwner();
      }

      // Job communications subcollection
      match /communications/{commId} {
        // Internal users can read job communications
        allow read: if isInternalUser();

        allow create: if isActiveUser();
        allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
      }
    }

    // Service Tickets collection
    match /serviceTickets/{ticketId} {
      // Internal users can read service tickets
      allow read: if isInternalUser();

      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isActiveUser() && resource.data.assignedTechId == request.auth.uid);
      allow delete: if isOwner();
    }

    // Leads collection
    match /leads/{leadId} {
      // Internal users can read leads (UI filters by assignment)
      // Customers can read their own leads (for Projects page)
      // Contractors can read available customer_portal leads (for lead feed)
      allow read: if isInternalUser() ||
        (isActiveUser() &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer' &&
         resource.data.customerId == request.auth.uid) ||
        (isContractor() && isActiveUser() &&
         resource.data.source == 'customer_portal' &&
         resource.data.status == 'new') ||
        // Contractors can read leads assigned to them
        (isContractor() && isActiveUser() &&
         resource.data.assignedTo == request.auth.uid);

      // Internal users can create leads (from inbound calls, manual entry, etc.)
      // Also allow public lead creation (for event QR code capture)
      // Public creates are field-whitelisted to prevent injection of privileged fields
      allow create: if isAdmin() ||
        (isInternalUser() && isActiveUser()) ||
        // Customers can create leads from the customer portal
        (isActiveUser() &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer' &&
         request.resource.data.source == 'customer_portal' &&
         request.resource.data.status == 'new' &&
         request.resource.data.customerId == request.auth.uid &&
         !request.resource.data.keys().hasAny(['assignedTo', 'salesRepId', 'linkedJobId', 'convertedBy'])) ||
        (request.resource.data.source == 'event' &&
         request.resource.data.status == 'new' &&
         request.resource.data.customer.name != null &&
         request.resource.data.customer.name != '' &&
         !request.resource.data.keys().hasAny(['assignedTo', 'salesRepId', 'linkedJobId', 'convertedBy']));

      // Sales reps can update leads assigned to them
      // Also allow updating to 'converted' status when linking to a job (only if assigned)
      // Also allow sales reps to CLAIM unassigned leads (assignedTo is null)
      allow update: if isAdmin() ||
        (isActiveUser() && resource.data.assignedTo == request.auth.uid) ||
        (isActiveUser() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales_rep' &&
          resource.data.assignedTo == request.auth.uid &&
          request.resource.data.status == 'converted' &&
          request.resource.data.linkedJobId != null) ||
        (isActiveUser() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales_rep' &&
          resource.data.assignedTo == null &&
          resource.data.status == 'new' &&
          request.resource.data.assignedTo == request.auth.uid &&
          request.resource.data.status == 'assigned') ||
        // Contractors can accept customer_portal leads (first-to-accept)
        (isContractor() && isActiveUser() &&
          resource.data.source == 'customer_portal' &&
          resource.data.status == 'new' &&
          (!('assignedTo' in resource.data) || resource.data.assignedTo == null) &&
          request.resource.data.assignedTo == request.auth.uid &&
          request.resource.data.status == 'assigned');
      allow delete: if isOwner();
    }

    // Campaigns collection
    match /campaigns/{campaignId} {
      // Internal users can read campaigns (needed for overview stats)
      // Only admins can create/modify campaigns
      allow read: if isInternalUser();
      allow write: if isAdmin();
    }

    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin() ||
        (isActiveUser() && resource.data.userId == request.auth.uid);

      allow create, update: if isAdmin();
      allow delete: if isOwner();
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      // Internal users can read all invoices
      // Contractors can also read their own invoices (where they are from or to)
      allow read: if isInternalUser() ||
        (isContractor() && isActiveUser() && (
          resource.data.from.contractorId == request.auth.uid ||
          resource.data.to.contractorId == request.auth.uid
        ));

      // Admins can create any invoice
      // Contractors can create invoices FROM themselves only
      allow create: if isAdmin() ||
        (isContractor() && isActiveUser() &&
          request.resource.data.from.entity == 'contractor' &&
          request.resource.data.from.contractorId == request.auth.uid);

      // Admins can update any invoice
      // Contractors can update their own draft invoices only (cannot change status or financial totals)
      allow update: if isAdmin() ||
        (isContractor() && isActiveUser() &&
          resource.data.from.contractorId == request.auth.uid &&
          resource.data.status == 'draft' &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'approvedBy', 'approvedAt', 'sentAt']));

      allow delete: if isOwner();
    }

    // Partners collection - External partner companies
    match /partners/{partnerId} {
      // Admins can read all partners
      allow read: if isAdmin();

      // Partners can read their own partner record
      allow read: if isPartner() && getUserPartnerId() == partnerId;

      // Only admins can create/update partners
      allow create, update: if isAdmin();
      allow delete: if isOwner();
    }

    // Labor Requests collection - Partner work requests
    match /laborRequests/{requestId} {
      // Admins can read all labor requests
      allow read: if isAdmin();

      // Partners can read their own company's requests
      allow read: if isPartner() && resource.data.partnerId == getUserPartnerId();

      // Partners can create requests for their own company
      allow create: if isPartner() &&
        isActiveUser() &&
        request.resource.data.partnerId == getUserPartnerId() &&
        request.resource.data.status == 'new';

      // Only admins can update (assign, change status)
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    // Partner Service Tickets collection
    match /partnerServiceTickets/{ticketId} {
      // Admins can read all partner tickets
      allow read: if isAdmin();

      // Partners can read their own company's tickets
      allow read: if isPartner() && resource.data.partnerId == getUserPartnerId();

      // Partners can create tickets for their own company
      allow create: if isPartner() &&
        isActiveUser() &&
        request.resource.data.partnerId == getUserPartnerId() &&
        request.resource.data.status == 'new';

      // Only admins can update (assign, change status)
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    // ========================================
    // INVENTORY MANAGEMENT COLLECTIONS
    // ========================================

    // Inventory Items collection - Materials and tools tracked (per-contractor)
    match /inventoryItems/{itemId} {
      // Admins can read all inventory items
      allow read: if isAdmin();

      // Contractors can read their own items
      allow read: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Admins can create/update/delete any items
      allow create, update: if isAdmin();

      // Contractors can create items for themselves
      allow create: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        request.resource.data.contractorId == request.auth.uid;

      // Contractors can update their own items
      allow update: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid &&
        request.resource.data.contractorId == request.auth.uid;

      // Contractors can delete their own items
      allow delete: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Owner can delete any items
      allow delete: if isOwner();
    }

    // Inventory Locations collection - Warehouses and contractor trucks
    match /inventoryLocations/{locationId} {
      // Internal users can read locations
      allow read: if isInternalUser();

      // Admins can create/update any location
      allow create, update: if isAdmin();

      // Contractors can create their own truck locations
      allow create: if isActiveUser() &&
        request.resource.data.contractorId == request.auth.uid &&
        request.resource.data.type == 'truck';

      allow delete: if isOwner();
    }

    // Inventory Stock collection - Current stock levels per location
    match /inventoryStock/{stockId} {
      // Internal users can read stock levels
      allow read: if isInternalUser();

      // Admins can update any stock
      allow create, update: if isAdmin();

      // Contractors can only update stock for their own truck location
      allow create, update: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        get(/databases/$(database)/documents/inventoryLocations/$(request.resource.data.locationId)).data.contractorId == request.auth.uid;

      // Admins and owner can delete any stock
      allow delete: if isAdmin();

      // Contractors can delete stock at their own locations
      allow delete: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        get(/databases/$(database)/documents/inventoryLocations/$(resource.data.locationId)).data.contractorId == request.auth.uid;
    }

    // Inventory Counts collection - Count session records
    match /inventoryCounts/{countId} {
      // Internal users can read count history
      allow read: if isInternalUser();

      // Admins can create counts for any location
      allow create: if isAdmin();

      // Contractors can create counts for their own truck
      allow create: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        get(/databases/$(database)/documents/inventoryLocations/$(request.resource.data.locationId)).data.contractorId == request.auth.uid;

      // Only admins can update/delete counts
      allow update, delete: if isAdmin();
    }

    // Receipts collection - Uploaded receipts with parsed data (per-contractor)
    match /receipts/{receiptId} {
      // Admins can read all receipts
      allow read: if isAdmin();

      // Contractors can read their own receipts (by contractorId)
      allow read: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Admins can create any receipt
      allow create: if isAdmin();

      // Contractors can create receipts for themselves
      allow create: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        request.resource.data.contractorId == request.auth.uid;

      // Admins can update any receipt (verify, add to P&L)
      allow update: if isAdmin();

      // Contractors can update their own pending receipts (edit parsed data)
      allow update: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid &&
        resource.data.status in ['pending', 'parsing', 'parsed'];

      // Contractors can delete their own receipts
      allow delete: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Owner can delete any receipts
      allow delete: if isOwner();
    }

    // Expenses collection - Direct expenses from receipts for P&L (per-contractor)
    match /expenses/{expenseId} {
      // Admins can read all expenses (needed for P&L)
      allow read: if isAdmin();

      // Contractors can read their own expenses (by contractorId)
      allow read: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Admins can create any expenses
      allow create: if isAdmin();

      // Contractors can create expenses for themselves (from receipts)
      allow create: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        request.resource.data.contractorId == request.auth.uid &&
        request.resource.data.entity == 'contractor';

      // Admins can update any expenses
      allow update: if isAdmin();

      // Contractors can update their own expenses (cannot change entity or contractorId)
      allow update: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['entity', 'contractorId', 'approvedBy', 'approvedAt']);

      // Contractors can delete their own expenses
      allow delete: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Owner can delete any expenses
      allow delete: if isOwner();
    }

    // ========================================
    // NOTIFICATIONS COLLECTION
    // ========================================

    // Notifications collection - User notifications
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Active users can create notifications (in-app notification system)
      allow create: if isActiveUser();

      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readAt', 'deliveredAt']);

      // Users can delete their own notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ========================================
    // RATING REQUESTS COLLECTION
    // ========================================

    // Rating Requests collection - Customer rating surveys
    match /ratingRequests/{requestId} {
      // Public read access: the random token in the URL acts as access control.
      // get() for direct lookups, list() needed for token-based queries from the public rating page.
      // Data exposed is limited (job number, contractor name, customer name, rating status).
      // The update rules below enforce one-time-submit protection.
      allow read: if true;

      // Only Cloud Functions (admin SDK) can create rating requests
      // This happens automatically when job status changes to 'complete'
      allow create: if false;

      // Allow public updates for rating submission
      // Only allow updating rating-related fields, and only if not already completed
      allow update: if resource.data.status == 'pending' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'comment', 'status', 'completedAt']) &&
        request.resource.data.status == 'completed' &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;

      // Admins can also update (e.g., send reminders)
      allow update: if isAdmin();

      // No deletes allowed
      allow delete: if false;
    }

    // ========================================
    // PAYOUTS COLLECTION
    // ========================================

    // Payouts collection - Tracks payments for jobs (lead fees, labor)
    match /payouts/{payoutId} {
      // Admins can read all payouts
      allow read: if isAdmin();

      // Contractors can read payouts where they are the recipient
      allow read: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor' &&
        resource.data.contractorId == request.auth.uid;

      // Only admins can create payouts (typically from job completion flow)
      allow create: if isAdmin();

      // Only admins can update payouts (mark as processed, etc.)
      allow update: if isAdmin();

      // Only owner can delete payouts
      allow delete: if isOwner();
    }

    // ========================================
    // SMS CONVERSATIONS COLLECTION
    // ========================================

    // SMS Conversations collection - Tracks SMS threads with leads
    match /smsConversations/{conversationId} {
      // Admins can read all SMS conversations
      allow read: if isAdmin();

      // Sales reps can read conversations for leads assigned to them
      allow read: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales_rep' &&
        get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.assignedTo == request.auth.uid;

      // Only Cloud Functions (admin SDK) can create/update conversations
      // Webhook handlers use admin SDK for these operations
      allow create: if false;
      allow update: if false;

      // Only owner can delete conversations
      allow delete: if isOwner();
    }

    // ========================================
    // VOICE CALLS COLLECTION
    // ========================================

    // Voice Calls collection - Tracks VAPI voice call records
    match /voiceCalls/{callId} {
      // Admins can read all voice calls
      allow read: if isAdmin();

      // Sales reps can read calls for leads assigned to them
      allow read: if isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales_rep' &&
        get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.assignedTo == request.auth.uid;

      // Only Cloud Functions (admin SDK) can create/update calls
      // API routes use admin SDK for these operations
      allow create: if false;
      allow update: if false;

      // Only owner can delete call records
      allow delete: if isOwner();
    }

    // ========================================
    // INBOUND CALLS COLLECTION
    // ========================================

    // Inbound Calls collection - Customer calls captured via VAPI
    match /inboundCalls/{callId} {
      // Internal users can read all inbound calls
      allow read: if isInternalUser();

      // Only Cloud Functions (admin SDK) can create calls
      // Webhook handlers use admin SDK for these operations
      allow create: if false;

      // Internal users can update calls (mark reviewed, contacted, convert, close)
      allow update: if isInternalUser() && isActiveUser();

      // Only owner can delete call records
      allow delete: if isOwner();
    }

    // ========================================
    // CONTRACTS COLLECTION
    // ========================================

    // Contracts collection - Signed contracts for jobs
    match /contracts/{contractId} {
      // Internal users can read all contracts
      allow read: if isInternalUser();

      // Admins can create any contract
      // Sales reps can create contracts for jobs where they are the sales rep
      allow create: if isAdmin() ||
        (isActiveUser() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales_rep' &&
          get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.salesRepId == request.auth.uid);

      // Admins can update any contract
      // Sales reps can update their own contracts (created by them)
      allow update: if isAdmin() ||
        (isActiveUser() && resource.data.createdBy == request.auth.uid);

      // Only owner can delete contracts
      allow delete: if isOwner();
    }

    // ========================================
    // ENTERPRISE COLLECTIONS
    // ========================================

    // ── KeyHub Network ──────────────────────────────────────────────────
    // Cross-tenant network connections for sharing contractors & marketplace.
    // Network docs are readable by admins of member tenants only.

    // Network config per tenant — stored in config/network
    // (Already covered by the config/{docId} rule above: read=authenticated, write=owner)

    // Networks collection — network membership and shared features
    match /networks/{networkId} {
      // Admins can read networks their tenant belongs to
      allow read: if isAdmin();

      // Only owner can create/update/delete networks
      allow create, update: if isOwner();
      allow delete: if isOwner();
    }

    // Connection requests — mutual agreement to join networks
    match /connectionRequests/{requestId} {
      // Admins can read requests involving their tenant
      allow read: if isAdmin();

      // Owner can create outbound requests
      allow create: if isOwner();

      // Owner can update (accept/reject) inbound requests
      allow update: if isOwner();

      // Owner can delete requests
      allow delete: if isOwner();
    }

    // Marketplace Listings — cross-dealer labor sharing
    // Network-scoped listings: tenants in the same network can READ listings
    // with a matching networkId, but never write to another tenant's listings
    match /marketplaceListings/{listingId} {
      allow read: if isActiveUser();
      allow create: if isAdmin() ||
        (isActiveUser() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pm');
      allow update: if isAdmin() ||
        (isActiveUser() && resource.data.dealerId == request.auth.uid) ||
        // Contractors can update to place bids (bids array)
        (isContractor() && isActiveUser());
      allow delete: if isAdmin();
    }

    // Remote Signing Sessions — e-signature tokens
    match /remoteSigningSessions/{sessionId} {
      // Public read via token query (verify endpoint uses admin SDK)
      // Internal users can list sessions for their contracts
      allow read: if isInternalUser();
      allow create: if isInternalUser() && isActiveUser();
      allow update: if isAdmin() ||
        (isInternalUser() && isActiveUser());
      allow delete: if isAdmin();
    }

    // Email Templates — automation config
    match /emailTemplates/{templateId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Email Queue — pending/sent emails
    match /emailQueue/{emailId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    // Webhook Endpoints — outbound webhook config
    match /webhookEndpoints/{endpointId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Webhook Deliveries — delivery logs
    match /webhookDeliveries/{deliveryId} {
      allow read: if isAdmin();
      allow create: if false; // Only admin SDK (dispatcher)
      allow delete: if isOwner();
    }

    // API Keys — external API access
    match /apiKeys/{keyId} {
      allow read: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Routing Rules — AI call routing config (developer-managed)
    match /routingRules/{ruleId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Saved Reports — report builder configs
    match /savedReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isActiveUser() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Internal messaging - conversations
    match /conversations/{conversationId} {
      // Participants can read their own conversations
      allow read: if isActiveUser() &&
        request.auth.uid in resource.data.participants;

      // Any active user can create a conversation (they must be a participant)
      allow create: if isActiveUser() &&
        request.auth.uid in request.resource.data.participants;

      // Participants can update conversation (for unreadCount, lastMessage)
      allow update: if isActiveUser() &&
        request.auth.uid in resource.data.participants;

      // Participants or admins can delete conversations (e.g. job chat cleanup on complete)
      allow delete: if isActiveUser() &&
        (request.auth.uid in resource.data.participants || isAdmin());

      // Messages subcollection
      match /messages/{messageId} {
        // Participants of the parent conversation can read messages
        allow read: if isActiveUser() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Participants can send messages (senderId must match auth uid)
        allow create: if isActiveUser() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;

        // Participants can update messages (for reactions)
        allow update: if isActiveUser() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Participants can delete messages (for job chat cleanup)
        allow delete: if isActiveUser() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Translation cache — UI string translations per language
    match /translations/{langId} {
      allow read: if isActiveUser();
      // Only server (admin SDK) writes translations
    }

    // Content translations — per-message/note translations
    match /contentTranslations/{contentId} {
      allow read: if isActiveUser();
      // Only server (admin SDK) writes translations
    }
  }
}
